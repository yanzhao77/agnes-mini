# Agnes Mini Configuration
# Copy this file to .env and fill in your settings.

# Agnes AI API Key (required for real API mode; leave empty for Mock mode)
AGNES_API_KEY=

# Agnes AI API Base URL (default: https://api.agnesai.com)
AGNES_BASE_URL=https://api.agnesai.com

# Default model names
AGNES_CHAT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# HTTP client settings
AGNES_TIMEOUT=60
AGNES_MAX_RETRIES=3

# Video polling settings
AGNES_VIDEO_POLL_INTERVAL=5
AGNES_VIDEO_POLL_TIMEOUT=600

# Output directory for generated files
AGNES_OUTPUT_DIR=./output

# Logging level (DEBUG, INFO, WARNING, ERROR)
AGNES_LOG_LEVEL=INFO
